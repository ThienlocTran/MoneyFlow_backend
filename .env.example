# MoneyFlow Backend - Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials.

# Spring profile: "local" for local DB, "production" for Neon
SPRING_PROFILES_ACTIVE=production

# Database connection (Neon PostgreSQL)
# Format: jdbc:postgresql://<neon-pooler-host>:5432/<database>?sslmode=require&channelBinding=require
MONEYFLOW_DB_URL=jdbc:postgresql://<neon-pooler-host>:5432/<database>?sslmode=require&channelBinding=require
MONEYFLOW_DB_USERNAME=<username>
MONEYFLOW_DB_PASSWORD=<password>

# Legacy fallback only. Prefer MONEYFLOW_* to avoid cross-project env collisions.
# DB_URL=jdbc:postgresql://<neon-pooler-host>:5432/<database>?sslmode=require&channelBinding=require
# DB_USERNAME=<username>
# DB_PASSWORD=<password>

# JWT. Use at least 32 bytes.
JWT_SECRET=<replace-with-at-least-32-byte-secret>
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30

# Connection pool tuning
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1

# Flyway for pre-existing Neon schema
FLYWAY_BASELINE_ON_MIGRATE=true

# Server port (optional)
# SERVER_PORT=8080
